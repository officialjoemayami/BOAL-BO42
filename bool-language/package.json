{
  "name": "boal-language",
  "displayName": "BOAL Language",
  "description": "Syntax highlighting for BOAL (BO42 Language)",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "boal",
        "aliases": ["BOAL", "boal"],
        "extensions": [".boal"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "boal",
        "scopeName": "source.boal",
        "path": "./syntaxes/boal.tmLanguage.json"
      }
    ]
  }
}