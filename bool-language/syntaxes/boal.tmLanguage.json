{
  "scopeName": "source.boal",
  "patterns": [
    {
      "name": "keyword.control.boal",
      "match": "\\b(ce|ci|attr|verify|out)\\b"
    },
    {
      "name": "constant.language.boal",
      "match": "\\b(valid|verified|null0)\\b"
    },
    {
      "name": "string.quoted.double.boal",
      "begin": "\"",
      "end": "\""
    },
    {
      "name": "comment.line.boal",
      "match": "//.*$"
    }
  ],
  "repository": {},
  "scopeName": "source.boal"
}